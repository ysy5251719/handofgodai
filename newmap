{
  "name": "map-connect-live",
  "version": "1.0.0",
  "scripts": {
    "dev": "webpack serve",
    "build": "webpack --mode production",
    "typecheck": "tsc --noEmit",
    "vercel-build": "webpack --mode production"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "tailwindcss": "^3.3.5"
  }
}
{
  "version": 2,
  "builds": [{
    "src": "package.json",
    "use": "@vercel/static-build",
    "config": { "distDir": "dist" }
  }],
  "routes": [
    { "src": "/functions/(.*)", "dest": "https://kb53e1zcbscc.meoo.app/functions/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
